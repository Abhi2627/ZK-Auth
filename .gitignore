# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Prisma
prisma/migrations/**/migration_lock.toml

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
.pytest_cache/

# ML model artifacts (large binaries — use DVC or separate storage)
ml-service/models/**/*.keras
ml-service/models/**/*.h5
ml-service/models/**/*.pkl
!ml-service/models/.gitkeep

# ZKP artifacts (generated — do not commit proving keys to version control)
backend/circuits/**/*.zkey
backend/circuits/**/*.r1cs
backend/circuits/**/*.wtns
backend/circuits/**/auth_js/
backend/circuits/**/merkle_disclosure_js/
!backend/circuits/**/*.circom
!backend/circuits/**/verification_key.json

# gRPC generated stubs
backend/src/grpc/generated/
ml-service/proto/*_pb2*.py
ml-service/proto/*_pb2*.pyi

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino-*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Flutter
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.pub-cache/

# Certs (never commit TLS certs)
certs/
*.pem
*.crt
*.key
!certs/.gitkeep
