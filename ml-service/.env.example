# ─── ZK-Auth ML Inference Service Environment Variables ──────────────────────
# Copy to .env and populate before running.

# ─── gRPC Server ──────────────────────────────────────────────────────────────
GRPC_PORT=50051
GRPC_MAX_WORKERS=10

# Use insecure channel in local dev (set to "true" ONLY for development)
GRPC_INSECURE=true

# mTLS certificates (production)
GRPC_CERT_PATH=./certs/server.crt
GRPC_KEY_PATH=./certs/server.key
GRPC_CA_CERT_PATH=./certs/ca.crt

# ─── TimescaleDB (training pipeline reads) ────────────────────────────────────
TIMESCALE_URL=postgresql://zkauth_lstm_role:CHANGE_ME@localhost:5433/zkauth_telemetry

# ─── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH=./models/lstm_v1/model.keras
SCALER_PATH=./models/lstm_v1/scaler.pkl
MODEL_VERSION=lstm_v1

# ─── Inference ────────────────────────────────────────────────────────────────
# Sliding window size (number of events per inference call)
INFERENCE_WINDOW_SIZE=50

# EMA smoothing factor for risk score (0 < alpha <= 1)
RISK_SMOOTHING_ALPHA=0.3

# Response timing jitter ceiling in ms (anti side-channel)
RESPONSE_JITTER_MAX_MS=50

# ─── Risk Thresholds ──────────────────────────────────────────────────────────
RISK_THRESHOLD_LOW=0.0
RISK_THRESHOLD_MEDIUM=0.45
RISK_THRESHOLD_HIGH=0.75
RISK_THRESHOLD_CRITICAL=0.90

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
