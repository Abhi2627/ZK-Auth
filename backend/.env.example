# ─── ZK-Auth Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and populate all values before running the server.
# NEVER commit .env to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── PostgreSQL (auth + zkp schemas) ─────────────────────────────────────────
DATABASE_URL="postgresql://zkauth_api_role:CHANGE_ME@localhost:5432/zkauth_db"

# ─── TimescaleDB (telemetry schema) ──────────────────────────────────────────
TIMESCALE_URL="postgresql://zkauth_api_role:CHANGE_ME@localhost:5433/zkauth_telemetry"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="CHANGE_ME"
REDIS_KEY_PREFIX="zkauth"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="CHANGE_ME_32_BYTE_HEX_SECRET_HERE"
JWT_REFRESH_SECRET="CHANGE_ME_32_BYTE_HEX_SECRET_HERE_2"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
JWT_ISSUER="zk-auth.internal"
JWT_AUDIENCE="zk-auth-clients"

# ─── ZKP Circuit Artifacts ────────────────────────────────────────────────────
AUTH_CIRCUIT_VKEY_PATH="./circuits/auth/verification_key.json"
DISCLOSURE_CIRCUIT_VKEY_PATH="./circuits/disclosure/verification_key.json"

# Challenge TTL in seconds
CHALLENGE_TTL_SECONDS=120

# Distributed lock TTL for nullifier two-phase commit
NULLIFIER_LOCK_TTL_SECONDS=5

# ─── Issuer Role (Phase 4 — replaced by JWT role claim in Phase 5) ────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ISSUER_SECRET_TOKEN="CHANGE_ME_ISSUER_SECRET"

# ─── gRPC — LSTM Inference Service ────────────────────────────────────────────
LSTM_GRPC_HOST="localhost"
LSTM_GRPC_PORT=50051
LSTM_GRPC_CERT_PATH="./certs/lstm-client.crt"
LSTM_GRPC_KEY_PATH="./certs/lstm-client.key"
LSTM_CA_CERT_PATH="./certs/ca.crt"
LSTM_GRPC_INSECURE="true"

# ─── Risk Thresholds ─────────────────────────────────────────────────────────
RISK_THRESHOLD_MEDIUM=0.45
RISK_THRESHOLD_HIGH=0.75
RISK_THRESHOLD_CRITICAL=0.90
RISK_STEP_UP_SOFT_THRESHOLD=0.75
RISK_STEP_UP_HARD_THRESHOLD=0.90
RISK_EMA_ALPHA=0.3

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_CHALLENGE_PER_MIN=10
RATE_LIMIT_AUTH_PER_MIN=20

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ─── Session ──────────────────────────────────────────────────────────────────
# ─── Step-Up ──────────────────────────────────────────────────────────────────
WS_PING_INTERVAL_MS=30000
STEP_UP_TTL_SECONDS=300

# ─── Recovery (Argon2id) ──────────────────────────────────────────────────────
# Memory: 64 MB (defeats GPU brute-force after DB exfiltration)
# Iterations: 3 (OWASP minimum for Argon2id)
# Parallelism: 1
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=1

# ─── Circuit Breaker (ML service fault tolerance) ─────────────────────────────
# gRPC call timeout before circuit increments failure counter
GRPC_TIMEOUT_MS=5000
# Consecutive failures before circuit trips to OPEN
GRPC_CIRCUIT_OPEN_THRESHOLD=5
# Milliseconds in OPEN state before attempting a probe (HALF_OPEN)
GRPC_CIRCUIT_RESET_MS=30000
