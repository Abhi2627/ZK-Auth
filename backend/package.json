{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "ZK-Auth API Gateway — Node.js/TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "proto:gen": "grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=esModuleInterop=true,outputServices=grpc-js --ts_proto_out=src/grpc/generated --proto_path=../packages/proto ../packages/proto/*.proto",
    "circuit:compile:auth": "circom circuits/auth/auth.circom --r1cs --wasm --sym -o circuits/auth/",
    "circuit:compile:disclosure": "circom circuits/disclosure/merkle_disclosure.circom --r1cs --wasm --sym -o circuits/disclosure/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.9",
    "@grpc/proto-loader": "^0.7.13",
    "@prisma/client": "^5.14.0",
    "@scure/bip39": "^1.3.0",
    "@zk-auth/types": "*",
    "argon2": "^0.31.2",
    "circomlibjs": "^0.1.7",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "snarkjs": "^0.7.4",
    "uuid": "^10.0.0",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/circomlibjs": "^0.1.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "grpc-tools": "^1.12.4",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.14.0",
    "ts-proto": "^1.176.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
