{
  "name": "@zk-auth/proto",
  "version": "1.0.0",
  "description": "Protobuf definitions for ZK-Auth gRPC services",
  "private": true,
  "scripts": {
    "generate": "npm run gen:js && npm run gen:ts",
    "gen:js": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./generated --grpc_out=grpc_mode=grpc-js:./generated --proto_path=. *.proto",
    "gen:ts": "protoc-gen-ts_proto --ts_proto_opt=esModuleInterop=true,outputServices=grpc-js --proto_path=. --ts_proto_out=./generated *.proto"
  },
  "devDependencies": {
    "grpc-tools": "^1.12.4",
    "ts-proto": "^1.176.0"
  }
}
